    "pg": "^8.12.0",
    "tsx": "^4.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.600.0",

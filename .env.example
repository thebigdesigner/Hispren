# ── MIGRATIONS ONLY. Never used by the running app. ──────────────────
# Neon's owner role. Owns the tables, so RLS does NOT apply to it.
MIGRATION_DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── THE APP. Tenant-scoped. RLS enforced. ────────────────────────────
# Use the POOLED host (-pooler). Role: hispren_app.
DATABASE_URL=postgresql://hispren_app:YOUR_APP_PW@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── PLATFORM. Cross-tenant, platform tables only. Blind to members. ──
# Role: hispren_platform. Used for: hostname->tenant, login, relay, billing.
PLATFORM_DATABASE_URL=postgresql://hispren_platform:YOUR_PLATFORM_PW@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

REDIS_URL=redis://localhost:6379
BASE_DOMAIN=localhost
PORT=3000
